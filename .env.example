# Random string, 32+ chars, used to encrypt the session cookie holding source/destination JWTs.
# Generate one with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Sitecore Cloud auth token endpoint. Override only for non-production Sitecore Cloud tenants.
SITECORE_AUTH_TOKEN_URL=https://auth.sitecorecloud.io/oauth/token

# OAuth audience sent when requesting a JWT. Override only for non-production Sitecore Cloud tenants.
SITECORE_AUTH_AUDIENCE=https://api.sitecorecloud.io
